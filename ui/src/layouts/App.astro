---
// App shell — every page of the purpose-built brain UI renders inside
// this layout. Mobile-native (AGENTS.md UI rule), light/dark via
// prefers-color-scheme, zero client JS except the search page.
interface Props {
  title: string;
  description?: string;
}
const { title, description = '' } = Astro.props;
const nav = [
  { href: '/', label: 'Briefing' },
  { href: '/dashboard/', label: 'Dashboard' },
  { href: '/trail/', label: 'Trail' },
  { href: '/graph/', label: 'Graph' },
  { href: '/home/', label: 'Corpus' },
  { href: '/onboarding/', label: 'Onboarding' },
  { href: '/search/', label: 'Search' },
];
const current = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · brain</title>
    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #ffffff; --bg-soft: #f5f6f8; --fg: #17202a;
        --muted: #5c6773; --line: #d9dee5; --accent: #4f5ee0;
        --ok: #1a7f4b; --warn: #a66300; --alert: #b3362c;
        --card: #ffffff; --chip: #eceef4;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #14171c; --bg-soft: #1b1f26; --fg: #e8eaee;
          --muted: #9aa4b0; --line: #2b323c; --accent: #8b96ff;
          --ok: #4fc98a; --warn: #e0a445; --alert: #ef7b6d;
          --card: #191d24; --chip: #242a33;
        }
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--bg); color: var(--fg);
        font: 16px/1.6 system-ui, -apple-system, "Segoe UI", sans-serif;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      header.app {
        position: sticky; top: 0; z-index: 10;
        background: var(--bg); border-bottom: 1px solid var(--line);
      }
      header.app .inner {
        max-width: 72rem; margin: 0 auto; padding: .55rem 1rem;
        display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
      }
      .brand { font-weight: 700; letter-spacing: .02em; color: var(--fg); }
      nav.top { display: flex; gap: .15rem; flex-wrap: wrap; }
      nav.top a {
        color: var(--muted); padding: .25rem .6rem; border-radius: .45rem;
        font-size: .95em;
      }
      nav.top a:hover { color: var(--fg); text-decoration: none;
        background: var(--bg-soft); }
      nav.top a[aria-current="page"] { color: var(--fg);
        background: var(--bg-soft); font-weight: 600; }
      main { max-width: 72rem; margin: 0 auto; padding: 1.25rem 1rem 4rem;
        overflow-wrap: break-word; }
      footer.app {
        max-width: 72rem; margin: 0 auto; padding: 1rem;
        color: var(--muted); font-size: .85em; border-top: 1px solid var(--line);
      }
      .chip {
        display: inline-block; background: var(--chip); color: var(--muted);
        border-radius: 99px; padding: .05rem .6rem; font-size: .78em;
        white-space: nowrap;
      }
      .chip.ok { color: var(--ok); }
      .chip.warn { color: var(--warn); }
      .chip.alert { color: var(--alert); }
      .chip.accent { color: var(--accent); }
      .cards {
        display: grid; gap: .75rem;
        grid-template-columns: repeat(auto-fill, minmax(min(17rem, 100%), 1fr));
        padding: 0; margin: .75rem 0; list-style: none;
      }
      .card {
        background: var(--card); border: 1px solid var(--line);
        border-radius: .7rem; padding: .8rem .95rem;
        display: flex; flex-direction: column; gap: .4rem;
      }
      .card h3 { margin: 0; font-size: 1em; line-height: 1.35; }
      .card h3 a { color: var(--fg); }
      .card p { margin: 0; color: var(--muted); font-size: .88em; }
      .card .chips { display: flex; gap: .35rem; flex-wrap: wrap; }
      .empty {
        border: 1px dashed var(--line); border-radius: .7rem;
        padding: .9rem 1rem; color: var(--muted); font-size: .92em;
        margin: .75rem 0;
      }
      .empty code { background: var(--chip); padding: 0 .3rem;
        border-radius: .3rem; }
    </style>
  </head>
  <body>
    <header class="app">
      <div class="inner">
        <a class="brand" href="/">Brain</a>
        <nav class="top">
          {nav.map((n) => (
            <a href={n.href}
               aria-current={current === n.href ? 'page' : undefined}
            >{n.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="app">
      Derived from the wiki — agents read the pages, humans read this.
    </footer>
  </body>
</html>
