---
// Search over the Pagefind index the build step generates
// (`pagefind --site <outdir>` in package.json build / ui-build.sh).
// Pagefind's bundled UI loads from the site's own /pagefind/ output —
// same-origin, no external requests.
import App from '../layouts/App.astro';
---
<App title="Search" description="Search the brain.">
  <h1 style="font-size:1.3em;">Search</h1>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <div id="search"></div>
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          autofocus: true,
        });
      } else {
        document.getElementById('search').textContent =
          'Search index not built yet — it lands with the next site build.';
      }
    });
  </script>
</App>
