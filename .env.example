# Machine-local toggles. Copy to .env (git-ignored) and edit.

# LOCAL_FIRST=true suspends the PR/CI ritual for single-operator
# sessions: work lands as local commits on the current branch, all
# validations still run locally. See AGENTS.md § Governance.
LOCAL_FIRST=true

# Connector credentials (0.3) — read-only-scoped tokens only.
# NOTION_TOKEN=secret_xxx
# SLACK_TOKEN=xoxb-xxx
# DD_API_KEY=xxx            # Datadog org API key
# DD_APP_KEY=xxx            # application key scoped to monitors_read+slos_read
# LANGFUSE_PUBLIC_KEY=pk-lf-xxx
# LANGFUSE_SECRET_KEY=sk-lf-xxx   # write-capable! dedicated project or self-host
